    private int GetWizardTotalSteps() => 3;

    private string GetPrimaryWizardAction()
    {
        if (lineWizardCompleted || facebookWizardCompleted)
        {
            return "เสร็จสิ้น";
        }

        if (IsLineWizard)
        {
            return isWizardBusy ? "กำลังบันทึก..." : "บันทึกและทดสอบ";
        }

        if (IsFacebookWizard && string.IsNullOrWhiteSpace(facebookAuthorizationUrl))
        {
            return isWizardBusy ? "กำลังเตรียม..." : "ลองดึงลิงก์อีกครั้ง";
        }

        return isWizardBusy ? "กำลังยืนยัน..." : "ยืนยันการเชื่อมต่อ";
    }

