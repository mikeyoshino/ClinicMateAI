@page "/clinic/inbox"
@layout ClinicLayout
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager NavigationManager
@implements IAsyncDisposable

<PageTitle>กล่องข้อความ - ClinicMateAI</PageTitle>

<!-- Filter bar -->
<div class="inbox-filter-bar">
    <div class="filter-channels">
        <button class="filter-btn @(ChannelFilter == "" ? "active" : "")" @onclick='() => SetChannelFilter("")'>ทั้งหมด</button>
        <button class="filter-btn line @(ChannelFilter == "LINE" ? "active" : "")" @onclick='() => SetChannelFilter("LINE")'>
            <span class="channel-dot line-dot"></span> LINE
        </button>
        <button class="filter-btn fb @(ChannelFilter == "Facebook" ? "active" : "")" @onclick='() => SetChannelFilter("Facebook")'>
            <span class="channel-dot fb-dot"></span> Facebook
        </button>
    </div>
    <div class="filter-read">
        <button class="filter-btn @(ReadFilter == "" ? "active" : "")" @onclick='() => SetReadFilter("")'>ทั้งหมด</button>
        <button class="filter-btn @(ReadFilter == "unread" ? "active" : "")" @onclick='() => SetReadFilter("unread")'>
            ยังไม่อ่าน
            @if (TotalUnread > 0)
            {
                <span class="unread-badge">@TotalUnread</span>
            }
        </button>
        <button class="filter-btn @(ReadFilter == "read" ? "active" : "")" @onclick='() => SetReadFilter("read")'>อ่านแล้ว</button>
    </div>
    <div class="filter-search">
        <input class="search-input" type="text" placeholder="🔍 ค้นหาชื่อลูกค้า..." @bind="SearchText" @bind:event="oninput" />
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Error))
{
    <div class="alert alert-danger mb-0">@Error</div>
}

<!-- 3-column inbox layout -->
<div class="inbox-layout">
    <!-- Column 1: Conversation list -->
    <div class="inbox-conversations">
        @if (IsLoadingConversations)
        {
            <div class="inbox-loading">
                <span class="spinner-border spinner-border-sm text-muted"></span>
                <span class="text-muted ms-2">กำลังโหลด...</span>
            </div>
        }
        else if (FilteredConversations.Count == 0)
        {
            <div class="inbox-empty">ไม่มีการสนทนา</div>
        }
        else
        {
            @foreach (var c in FilteredConversations)
            {
                <div class="conv-item @(SelectedConversationId == c.ConversationId ? "selected" : "") @(!c.IsRead ? "unread" : "")"
                     @onclick="() => SelectConversationAsync(c)">
                    <div class="conv-header">
                        <span class="conv-name">@c.CustomerDisplayName</span>
                        <span class="conv-time">@FormatTime(c.LastMessageAtUtc)</span>
                    </div>
                    <div class="conv-meta">
                        <span class="channel-tag @c.Channel.ToLower()">@c.Channel</span>
                        @if (!c.IsRead && c.UnreadCount > 0)
                        {
                            <span class="unread-count">@c.UnreadCount</span>
                        }
                        @if (c.AssignedStaff is not null)
                        {
                            <span class="claimed-tag">👤 @c.AssignedStaff</span>
                        }
                    </div>
                    @if (!string.IsNullOrWhiteSpace(c.LastMessagePreview))
                    {
                        <div class="conv-preview">@c.LastMessagePreview</div>
                    }
                </div>
            }
        }
    </div>

    <!-- Column 2: Message thread -->
    <div class="inbox-thread">
        @if (SelectedConversation is null)
        {
            <div class="thread-empty">
                <span>เลือกการสนทนาเพื่อดูข้อความ</span>
            </div>
        }
        else
        {
            <div class="thread-header">
                <div class="thread-title">
                    <strong>@SelectedConversation.CustomerDisplayName</strong>
                    <span class="channel-tag @SelectedConversation.Channel.ToLower() ms-2">@SelectedConversation.Channel</span>
                </div>
                <div class="thread-actions">
                    @if (SelectedConversation.AssignedStaff is null)
                    {
                        <button class="btn-claim" @onclick="ClaimAsync">รับเคส</button>
                    }
                    else if (SelectedConversation.AssignedStaff == CurrentStaffName)
                    {
                        <span class="claim-mine">คุณรับเคสนี้แล้ว</span>
                        <button class="btn-release" @onclick="ReleaseAsync">คืนเคส</button>
                    }
                    else
                    {
                        <span class="claim-other">👤 @SelectedConversation.AssignedStaff</span>
                        <button class="btn-override" @onclick="() => ShowOverrideConfirm = true">รับต่อ</button>
                    }
                </div>
            </div>

            @if (ShowOverrideConfirm)
            {
                <div class="override-confirm">
                    <span>@SelectedConversation.AssignedStaff กำลังดูแลเคสนี้อยู่ ต้องการรับต่อหรือไม่?</span>
                    <button class="btn-confirm-override" @onclick="ClaimOverrideAsync">ยืนยัน</button>
                    <button class="btn-cancel-override" @onclick="() => ShowOverrideConfirm = false">ยกเลิก</button>
                </div>
            }

            <div class="thread-messages" id="thread-messages">
                @if (IsLoadingMessages)
                {
                    <div class="inbox-loading">
                        <span class="spinner-border spinner-border-sm text-muted"></span>
                    </div>
                }
                else
                {
                    @foreach (var m in Messages)
                    {
                        <div class="msg @(m.SenderType == "Customer" ? "msg-customer" : "msg-staff")">
                            <div class="msg-bubble">@m.Text</div>
                            <div class="msg-time">@m.SentAtUtc.ToLocalTime().ToString("HH:mm")</div>
                        </div>
                    }
                }
            </div>

            <div class="thread-reply">
                <textarea class="reply-input" placeholder="พิมพ์ข้อความ..." @bind="ReplyText" rows="3"></textarea>
                <div class="reply-actions">
                    @if (SelectedConversation.AiStatus == "DraftReady")
                    {
                        <span class="ai-draft-badge">AI Draft พร้อม</span>
                    }
                    <button class="btn-send" disabled="@(string.IsNullOrWhiteSpace(ReplyText))" @onclick="SendReplyAsync">ส่ง</button>
                </div>
            </div>
        }
    </div>

    <!-- Column 3: Customer panel -->
    <div class="inbox-customer-panel">
        @if (SelectedConversation is null)
        {
            <div class="panel-empty">เลือกการสนทนา</div>
        }
        else
        {
            <div class="panel-section">
                <div class="panel-avatar">👤</div>
                <div class="panel-name">@SelectedConversation.CustomerDisplayName</div>
                <div class="panel-channel channel-tag @SelectedConversation.Channel.ToLower()">@SelectedConversation.Channel</div>
            </div>
            <div class="panel-section">
                <div class="panel-row">
                    <span class="panel-label">สถานะ</span>
                    <span class="panel-value">@SelectedConversation.Status</span>
                </div>
                <div class="panel-row">
                    <span class="panel-label">AI</span>
                    <span class="panel-value ai-status-@SelectedConversation.AiStatus.ToLower()">@GetAiStatusLabel(SelectedConversation.AiStatus)</span>
                </div>
            </div>
            <div class="panel-divider"></div>
            <div class="panel-section-title">📋 ข้อมูลเพิ่มเติม</div>
            <div class="panel-section muted">
                <div class="panel-row"><span class="panel-label">นัดหมาย</span><span class="panel-value">-</span></div>
                <div class="panel-row"><span class="panel-label">โปรโมชั่น</span><span class="panel-value">-</span></div>
            </div>
        }
    </div>
</div>

@code {
    // ---- State ----
    private string ChannelFilter { get; set; } = "";
    private string ReadFilter { get; set; } = "";
    private string SearchText { get; set; } = "";
    private string? Error { get; set; }
    private bool IsLoadingConversations { get; set; }
    private bool IsLoadingMessages { get; set; }
    private bool ShowOverrideConfirm { get; set; }
    private Guid? SelectedConversationId { get; set; }
    private string ReplyText { get; set; } = "";

    // Stub: in production, derive from auth context
    private string CurrentStaffName => "Staff";

    private List<InboxConversationVm> Conversations { get; } = [];
    private List<InboxMessageVm> Messages { get; } = [];

    private InboxConversationVm? SelectedConversation =>
        Conversations.FirstOrDefault(x => x.ConversationId == SelectedConversationId);

    private List<InboxConversationVm> FilteredConversations => Conversations
        .Where(c =>
            (string.IsNullOrEmpty(ChannelFilter) || c.Channel == ChannelFilter) &&
            (string.IsNullOrEmpty(ReadFilter) ||
                (ReadFilter == "unread" && !c.IsRead) ||
                (ReadFilter == "read" && c.IsRead)) &&
            (string.IsNullOrEmpty(SearchText) ||
                c.CustomerDisplayName.Contains(SearchText, StringComparison.OrdinalIgnoreCase)))
        .ToList();

    private int TotalUnread => Conversations.Where(c =>
        (string.IsNullOrEmpty(ChannelFilter) || c.Channel == ChannelFilter) && !c.IsRead)
        .Sum(c => c.UnreadCount);

    // ---- Clinic context (uses first clinic for now) ----
    private Guid ClinicId { get; set; }

    // ---- SignalR ----
    private HubConnection? _hubConnection;

    protected override async Task OnInitializedAsync()
    {
        await LoadClinicAndConversationsAsync();
        try { await ConnectSignalRAsync(); } catch { /* SignalR unavailable — polling fallback */ }
    }

    private async Task LoadClinicAndConversationsAsync()
    {
        IsLoadingConversations = true;
        try
        {
            var client = HttpClientFactory.CreateClient();
            var clinicsUrl = NavigationManager.ToAbsoluteUri("/api/inbox/clinics").ToString();
            var clinicsResp = await client.GetAsync(clinicsUrl);
            if (!clinicsResp.IsSuccessStatusCode) { Error = "ไม่สามารถโหลดข้อมูลคลินิกได้"; return; }

            var clinics = await clinicsResp.Content.ReadFromJsonAsync<List<InboxClinicVm>>();
            if (clinics is null || clinics.Count == 0) { Error = "ไม่พบคลินิก"; return; }

            ClinicId = clinics[0].ClinicId;
            await LoadConversationsAsync();
        }
        finally
        {
            IsLoadingConversations = false;
        }
    }

    private async Task LoadConversationsAsync()
    {
        var client = HttpClientFactory.CreateClient();
        var url = NavigationManager.ToAbsoluteUri($"/api/inbox/conversations?clinicId={ClinicId}&take=100").ToString();
        var resp = await client.GetAsync(url);
        if (!resp.IsSuccessStatusCode) { Error = $"โหลดการสนทนาล้มเหลว ({(int)resp.StatusCode})"; return; }

        var items = await resp.Content.ReadFromJsonAsync<List<InboxConversationVm>>();
        Conversations.Clear();
        if (items is not null) Conversations.AddRange(items);
    }

    private async Task SelectConversationAsync(InboxConversationVm conv)
    {
        SelectedConversationId = conv.ConversationId;
        ShowOverrideConfirm = false;
        Messages.Clear();
        IsLoadingMessages = true;

        // Mark as read
        _ = MarkReadAsync(conv.ConversationId);

        try
        {
            var client = HttpClientFactory.CreateClient();
            var url = NavigationManager.ToAbsoluteUri($"/api/inbox/conversations/{conv.ConversationId}/messages?clinicId={ClinicId}").ToString();
            var resp = await client.GetAsync(url);
            if (resp.IsSuccessStatusCode)
            {
                var items = await resp.Content.ReadFromJsonAsync<List<InboxMessageVm>>();
                if (items is not null) Messages.AddRange(items);
            }
        }
        finally
        {
            IsLoadingMessages = false;
        }
    }

    private async Task MarkReadAsync(Guid conversationId)
    {
        var c = Conversations.FirstOrDefault(x => x.ConversationId == conversationId);
        if (c is null || (c.IsRead && c.UnreadCount == 0)) return;
        c.IsRead = true;
        c.UnreadCount = 0;
        StateHasChanged();

        var client = HttpClientFactory.CreateClient();
        var url = NavigationManager.ToAbsoluteUri($"/api/inbox/conversations/{conversationId}/read?clinicId={ClinicId}").ToString();
        await client.PostAsync(url, null);
    }

    private async Task ClaimAsync()
    {
        if (SelectedConversationId is null) return;
        var client = HttpClientFactory.CreateClient();
        var url = NavigationManager.ToAbsoluteUri($"/api/inbox/conversations/{SelectedConversationId}/claim?clinicId={ClinicId}&staffName={Uri.EscapeDataString(CurrentStaffName)}").ToString();
        var resp = await client.PostAsync(url, null);
        if (resp.IsSuccessStatusCode)
        {
            var c = Conversations.FirstOrDefault(x => x.ConversationId == SelectedConversationId);
            if (c is not null) { c.AssignedStaff = CurrentStaffName; }
        }
        else if (resp.StatusCode == System.Net.HttpStatusCode.Conflict)
        {
            var body = await resp.Content.ReadFromJsonAsync<ConflictResponse>();
            Error = $"เคสนี้ถูกรับโดย {body?.Conflict} แล้ว";
        }
    }

    private async Task ClaimOverrideAsync()
    {
        ShowOverrideConfirm = false;
        await ClaimAsync();
    }

    private async Task ReleaseAsync()
    {
        if (SelectedConversationId is null) return;
        var client = HttpClientFactory.CreateClient();
        var url = NavigationManager.ToAbsoluteUri($"/api/inbox/conversations/{SelectedConversationId}/release?clinicId={ClinicId}").ToString();
        await client.PostAsync(url, null);
        var c = Conversations.FirstOrDefault(x => x.ConversationId == SelectedConversationId);
        if (c is not null) { c.AssignedStaff = null; }
    }

    private Task SendReplyAsync()
    {
        // TODO: wire to POST /api/inbox/conversations/{id}/reply when implemented
        ReplyText = "";
        return Task.CompletedTask;
    }

    private void SetChannelFilter(string v) { ChannelFilter = v; }
    private void SetReadFilter(string v) { ReadFilter = v; }

    private static string FormatTime(DateTime utc)
    {
        var local = utc.ToLocalTime();
        var diff = DateTime.Now - local;
        if (diff.TotalMinutes < 1) return "เมื่อกี้";
        if (diff.TotalHours < 1) return $"{(int)diff.TotalMinutes} นาทีที่แล้ว";
        if (diff.TotalDays < 1) return local.ToString("HH:mm");
        if (diff.TotalDays < 7) return local.ToString("ddd HH:mm");
        return local.ToString("d MMM");
    }

    private static string GetAiStatusLabel(string status) => status switch
    {
        "AutoReplied" => "ตอบอัตโนมัติ",
        "DraftReady" => "ร่างพร้อม",
        "Escalated" => "ส่งต่อแล้ว",
        _ => "-"
    };

    // ---- SignalR ----
    private async Task ConnectSignalRAsync()
    {
        _hubConnection = new HubConnectionBuilder()
            .WithUrl(NavigationManager.ToAbsoluteUri("/hubs/inbox"))
            .WithAutomaticReconnect()
            .Build();

        _hubConnection.On<ConversationUpdatedVm>("ConversationUpdated", evt =>
        {
            var existing = Conversations.FirstOrDefault(x => x.ConversationId == evt.ConversationId);
            if (existing is not null)
            {
                existing.IsRead = evt.IsRead;
                existing.UnreadCount = evt.UnreadCount;
                existing.Status = evt.Status;
                existing.AiStatus = evt.AiStatus;
                existing.AssignedStaff = evt.AssignedStaff;
                existing.LastMessageAtUtc = evt.LastMessageAtUtc;
                existing.LastMessagePreview = evt.LastMessagePreview;
            }
            else
            {
                Conversations.Insert(0, new InboxConversationVm
                {
                    ConversationId = evt.ConversationId,
                    CustomerDisplayName = evt.CustomerDisplayName,
                    Channel = evt.Channel,
                    Status = evt.Status,
                    AiStatus = evt.AiStatus,
                    IsRead = evt.IsRead,
                    UnreadCount = evt.UnreadCount,
                    AssignedStaff = evt.AssignedStaff,
                    LastMessageAtUtc = evt.LastMessageAtUtc,
                    LastMessagePreview = evt.LastMessagePreview
                });
            }
            InvokeAsync(StateHasChanged);
        });

        _hubConnection.On<ConversationClaimedVm>("ConversationClaimed", evt =>
        {
            var c = Conversations.FirstOrDefault(x => x.ConversationId == evt.ConversationId);
            if (c is not null) { c.AssignedStaff = evt.AssignedStaff; c.Status = evt.Status; }
            InvokeAsync(StateHasChanged);
        });

        await _hubConnection.StartAsync();
        if (ClinicId != Guid.Empty)
            await _hubConnection.InvokeAsync("JoinClinic", ClinicId.ToString());
    }

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection is not null)
            await _hubConnection.DisposeAsync();
    }

    // ---- View models ----
    private sealed class InboxClinicVm
    {
        public Guid ClinicId { get; set; }
        public string Name { get; set; } = string.Empty;
    }

    private sealed class InboxConversationVm
    {
        public Guid ConversationId { get; set; }
        public string Channel { get; set; } = string.Empty;
        public string ExternalConversationId { get; set; } = string.Empty;
        public string CustomerDisplayName { get; set; } = string.Empty;
        public string Status { get; set; } = "Open";
        public string AiStatus { get; set; } = "None";
        public bool IsRead { get; set; }
        public int UnreadCount { get; set; }
        public string? AssignedStaff { get; set; }
        public DateTime? ClaimedAt { get; set; }
        public DateTime LastMessageAtUtc { get; set; }
        public string LastMessagePreview { get; set; } = string.Empty;
    }

    private sealed class InboxMessageVm
    {
        public string SenderType { get; set; } = string.Empty;
        public string Text { get; set; } = string.Empty;
        public DateTime SentAtUtc { get; set; }
    }

    private sealed class ConversationUpdatedVm
    {
        public Guid ConversationId { get; set; }
        public string CustomerDisplayName { get; set; } = string.Empty;
        public string Channel { get; set; } = string.Empty;
        public string Status { get; set; } = string.Empty;
        public string AiStatus { get; set; } = string.Empty;
        public bool IsRead { get; set; }
        public int UnreadCount { get; set; }
        public string? AssignedStaff { get; set; }
        public DateTime LastMessageAtUtc { get; set; }
        public string LastMessagePreview { get; set; } = string.Empty;
    }

    private sealed class ConversationClaimedVm
    {
        public Guid ConversationId { get; set; }
        public string? AssignedStaff { get; set; }
        public string Status { get; set; } = string.Empty;
    }

    private sealed class ConflictResponse
    {
        public string? Conflict { get; set; }
    }
}
