@implements IDisposable
@inject NavigationManager NavigationManager

<div class="menu-header">
    <div class="menu-logo">CM</div>
    <div>
        <div class="menu-title">ClinicMateAI</div>
        <div class="menu-subtitle">MVP Dashboard</div>
    </div>
</div>

<button class="navbar-toggler" type="button" title="Toggle navigation" @onclick="ToggleMenu">
    <span></span>
    <span></span>
    <span></span>
</button>

<div class="nav-scrollable @(isMenuOpen ? "open" : string.Empty)">
    <nav class="nav-list">
        <NavLink class="nav-link" href="" Match="NavLinkMatch.All">ภาพรวม</NavLink>
        <NavLink class="nav-link" href="clinics">จัดการคลินิก</NavLink>
        <NavLink class="nav-link" href="setup">ตั้งค่าคลินิก</NavLink>
        <NavLink class="nav-link" href="inbox">กล่องข้อความ</NavLink>
        <NavLink class="nav-link" href="appointments">ตารางนัดหมาย</NavLink>
        <NavLink class="nav-link" href="promotions">โปรโมชัน</NavLink>
        <NavLink class="nav-link" href="ai-test">ทดสอบ AI</NavLink>
        <NavLink class="nav-link" href="integrations">การเชื่อมต่อ</NavLink>
        <NavLink class="nav-link" href="platform-admin">ผู้ดูแลแพลตฟอร์ม</NavLink>

        <AuthorizeView>
            <Authorized>
                <NavLink class="nav-link user-link" href="Account/Manage">@context.User.Identity?.Name</NavLink>
                <form action="Account/Logout" method="post" class="logout-form">
                    <AntiforgeryToken />
                    <input type="hidden" name="ReturnUrl" value="@currentUrl" />
                    <button type="submit" class="nav-link logout-button">ออกจากระบบ</button>
                </form>
            </Authorized>
            <NotAuthorized>
                <NavLink class="nav-link user-link" href="Account/Login">เข้าสู่ระบบ</NavLink>
            </NotAuthorized>
        </AuthorizeView>
    </nav>
</div>

@code {
    private string? currentUrl;
    private bool isMenuOpen;

    protected override void OnInitialized()
    {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        isMenuOpen = false;
        StateHasChanged();
    }

    private void ToggleMenu()
    {
        isMenuOpen = !isMenuOpen;
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}
